APP_NAME="Etec SAM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# =======================================================
# APP_URL - CONFIGURE CONFORME SEU AMBIENTE
# =======================================================
# XAMPP local (C:\\xampp\\htdocs\\etecsam):
APP_URL=http://localhost/etecsam/public
#
# Se estiver usando artisan serve (php artisan serve):
# APP_URL=http://localhost:8000
#
# Servidor de producao (Hostinger):
# APP_URL=https://www.etecsam.com.br
# =======================================================

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

# =======================================================
# BANCO DE DADOS - SQLite (padrao para desenvolvimento)
# =======================================================
# O arquivo database/database.sqlite NAO e commitado no Git.
# Cada ambiente (local, producao) tem seu proprio banco.
# Para criar o banco local: touch database/database.sqlite
# Depois execute: php artisan migrate
# E crie o admin: php artisan db:seed --class=AdminSeeder
# =======================================================
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=etecsam
# DB_USERNAME=root
# DB_PASSWORD=

# =======================================================
# STORAGE / IMAGENS
# =======================================================
# Imagens enviadas via admin ficam em: storage/app/public/
# Para criar o link simbolico local:
# php artisan storage:link
# Isso cria public/storage apontando para storage/app/public/
#
# IMPORTANTE: A pasta storage/app/public/ NAO e commitada.
# Cada ambiente tem suas proprias imagens.
# =======================================================

FILESYSTEM_DISK=local

# =======================================================
# CACHE E SESSAO
# =======================================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

# =======================================================
# EMAIL (opcional para desenvolvimento)
# =======================================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@etecsam.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# =======================================================
# OUTRAS CONFIGURACOES
# =======================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
